@incollection{schleiterHeterogeneityEarlyElections2024,
  title = {The {{Heterogeneity}} of {{Early Elections}}},
  booktitle = {New {{Developments}} in the {{Study}} of {{Coalition Governments}}},
  author = {Schleiter, Petra and Issar, Sukriti},
  editor = {Dumont, Patrick and Grofman, Bernard and Bergman, Torbj{\"o}rn and Louwerse, Tom},
  year = 2024,
  pages = {39--71},
  publisher = {Springer Nature Switzerland},
  address = {Cham},
  doi = {10.1007/978-3-031-69347-2_3},
  abstract = {Early elections can either be used by the prime minister's party to consolidate its position or they can be directed against that party when its hold on power slips. These two types of elections occur under different conditions. The literatures on government terminations and the political economy of election timing only partially accommodate that heterogeneity: Neither provides a fully developed account of the conditions that enable the two types of elections and both tend to treat early elections as a single homogeneous outcome in empirical work. This chapter addresses these shortcomings. We characterize the difference between the two classes of elections, offer the first account of the constitutional, economic and political circumstances that make each type more likely, and test it using a dataset of 327 East and West European elections. Our results reveal that the two early election types have different predictors and make clear that premature polls cannot be analysed as a single outcome.},
  isbn = {978-3-031-69347-2},
  langid = {english},
  keywords = {Early elections,Government termination,Parliamentary democracies,Political surfing}
}

@article{schultzExplainingImmigrationPolicy2021,
  title = {Explaining the Immigration Policy Mix: {{Countries}}' Relative Openness to Asylum and Labour Migration},
  shorttitle = {Explaining the Immigration Policy Mix},
  author = {Schultz, Caroline and Lutz, Philipp and Simon, Stephan},
  year = 2021,
  journal = {European Journal of Political Research},
  volume = {60},
  number = {4},
  pages = {763--784},
  issn = {1475-6765},
  doi = {10.1111/1475-6765.12422},
  abstract = {Western democracies have developed complex policies to manage migration flows. Much of the scholarly literature and political discourse assume that countries have become increasingly selective and that they prioritise economic intakes. Despite clear efforts by policymakers to distinguish between refugees and migrant workers, we know surprisingly little about how countries combine different policy dimensions and which factors shape their relative openness to different target groups. In this article, we shed light on how countries combine two of the main admission channels, asylum and labour migration, by introducing the concept of the `immigration policy mix'. A comparative analysis of 33 OECD countries between 1980 and 2010 examines the pattern and drivers behind their immigration policy mix: Does the policy mix follow a pattern of convergence, is it subject to political dynamics or is it path dependent? The results reveal that despite a shift in political sympathies from asylum to labour migration, countries' immigration policy mixes have strongly converged into more liberal policies overall. The immigration policy mix primarily reflects governments' limited room to manoeuvre due to competing political pressures. These insights demonstrate that the immigration policy mix serves to enhance our understanding of countries' complex regulation of immigration.},
  copyright = {\copyright{} 2020 The Authors. European Journal of Political Research published by John Wiley \& Sons Ltd on behalf of European Consortium for Political Research},
  langid = {english},
  keywords = {asylum,immigration,labour,migration policy,policy mix},
  file = {C\:\\Users\\jupf0\\Zotero\\storage\\A72HPBGT\\Schultz et al. - 2021 - Explaining the immigration policy mix Countries' relative openness to asylum and labour migration.pdf;C\:\\Users\\jupf0\\Zotero\\storage\\ZQQZNRBF\\1475-6765.html}
}

