@article{sebokLeveragingOpenLarge2025,
  title = {Leveraging {{Open Large Language Models}} for {{Multilingual Policy Topic Classification}}: {{The Babel Machine Approach}}},
  shorttitle = {Leveraging {{Open Large Language Models}} for {{Multilingual Policy Topic Classification}}},
  author = {Seb{\H o}k, Mikl{\'o}s and M{\'a}t{\'e}, {\'A}kos and Ring, Orsolya and Kov{\'a}cs, Viktor and Lehoczki, Rich{\'a}rd},
  year = 2025,
  month = apr,
  journal = {Social Science Computer Review},
  volume = {43},
  number = {2},
  pages = {295--317},
  publisher = {SAGE Publications Inc},
  issn = {0894-4393},
  doi = {10.1177/08944393241259434},
  abstract = {The article presents an open-source and freely available natural language processing system for comparative policy studies. The CAP Babel Machine allows for the automated classification of input files based on the 21 major policy topics of the codebook of the Comparative Agendas Project (CAP). By using multilingual XLM-RoBERTa large language models, the pipeline can produce state-of-the-art level outputs for selected pairs of languages and domains (such as media or parliamentary speech). For 24 cases out of 41, the weighted macro F1 of our language-domain models surpassed 0.75 (and, for 6 language-domain pairs, 0.90). Besides macro F1, for most major topic categories, the distribution of micro F1 scores is also centered around 0.75. These results show that the CAP Babel machine is a viable alternative for human coding in terms of validity at less cost and higher reliability. The proposed research design also has significant possibilities for scaling in terms of leveraging new models, covering new languages, and adding new datasets for fine-tuning. Based on our tests on manifesto data, a different policy classification scheme, we argue that model-pipeline frameworks such as the Babel Machine can, over time, potentially replace double-blind human coding for a multitude of comparative classification problems.},
  langid = {english},
  file = {C:\Users\jupf0\Zotero\storage\ZSR6VZSM\Sebők et al. - 2025 - Leveraging Open Large Language Models for Multilingual Policy Topic Classification The Babel Machin.pdf}
}

@book{simmonsPoliticsTechnologicalProgress2016,
  title = {The {{Politics}} of {{Technological Progress}}: {{Parties}}, {{Time Horizons}} and {{Long-term Economic Development}}},
  shorttitle = {The {{Politics}} of {{Technological Progress}}},
  author = {Simmons, Joel W.},
  year = 2016,
  publisher = {Cambridge University Press},
  address = {Cambridge},
  doi = {10.1017/9781316536148},
  abstract = {Why are some countries richer than others and why do some economies grow more rapidly? The Politics of Technological Progress answers these vital questions by highlighting the importance of technological progress for sustained economic development. The author also explains why some countries exhibit faster technological progress than others. Armed with a wealth of cross-national empirical evidence, Professor Simmons stresses the importance of properly constructed political parties for establishing an environment conducive to technological progress. 'Well-institutionalized' ruling parties are essential for technological progress, he argues, because only in such parties are time horizons long enough for governments to accept the deferred returns that are an inherent feature of government efforts to encourage innovation and technology adoption in the economy.},
  isbn = {978-1-107-14577-1},
