@article{clarkQuantitativeApplicationDiffusion2022,
  title = {A Quantitative Application of Diffusion of Innovations for Modeling the Spread of Conservation Behaviors},
  author = {Clark, Matt and Andrews, Jeffrey and Hillis, Vicken},
  year = 2022,
