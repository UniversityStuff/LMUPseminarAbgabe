  publisher = {SAGE Publications},
  issn = {1536-867X, 1536-8734},
  doi = {10.1177/1536867x0700700301},
  abstract = {In this paper I present a new Stata program, xtscc, which estimates pooled OLS/WLS and fixed effects (within) regression models with Driscoll and Kraay (Review of Economics and Statistics 80: 549-560) standard errors. By running Monte Carlo simulations, I compare the finite sample properties of the crosssectional dependence consistent Driscoll-Kraay estimator with the properties of other, more commonly employed covariance matrix estimators that do not account for cross-sectional dependence. The results indicate that Driscoll-Kraay standard errors are well calibrated when cross-sectional dependence is present. However, erroneously ignoring cross-sectional correlation in the estimation of panel models can lead to severely biased statistical results. I illustrate the use of the xtscc program by considering an application from empirical finance. Thereby, I also propose a Hausman-type test for fixed-effects that is robust to very general forms of cross-sectional and temporal dependence.},
  copyright = {https://journals.sagepub.com/page/policies/text-and-data-mining-license},
  langid = {english},
  file = {C:\Users\jupf0\Zotero\storage\HLKTR4QH\Hoechle - 2007 - Robust Standard Errors for Panel Regressions with Cross-Sectional Dependence.pdf}
}

